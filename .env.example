# Base de données
DATABASE_URL="postgresql://user:password@localhost:5432/aios"

# Auth (Clerk) — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# Paiements (Stripe)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."                # webhook /api/webhooks/stripe (Stripe des entreprises clientes)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Monétisation de la plateforme AIOS (Phase 10) — webhook et prix DISTINCTS du précédent
STRIPE_PLATFORM_WEBHOOK_SECRET="whsec_..."       # webhook /api/webhooks/stripe-platform
STRIPE_PRICE_PRO="price_..."                     # ID du prix récurrent du plan Pro
STRIPE_PRICE_BUSINESS="price_..."                # ID du prix récurrent du plan Business

# Storage (Supabase)
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="..."

# Redis (queues / cache)
REDIS_URL="redis://localhost:6379"

# Fournisseurs IA (système multi-modèle)
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."
GOOGLE_AI_API_KEY="..."
DEEPSEEK_API_KEY="..."

# Intégrations externes (Phase 9)
# Token GitHub avec droits d'écriture sur les dépôts des projets — permet au Dev Agent d'ouvrir de vraies PR
GITHUB_TOKEN="ghp_..."
